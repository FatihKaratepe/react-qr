{
  "name": "@mfk/react-qr",
  "version": "1.0.0",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --sourcemap"
  },
  "peerDependencies": {
    "react": "^18 || ^19",
    "react-dom": "^18 || ^19"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  },
  "author": "Fatih Karatepe",
  "license": "MIT",
  "exports": {
    ".": {
      "types": {
        "import": "./dist/index.d.ts",
        "require": "./dist/index.d.cts"
      },
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "description": "A customizable and easy-to-use React component for generating QR codes with support for SVG, Canvas, and optional embedded images.",
  "keywords": [
    "react",
    "qr",
    "qrcode",
    "react-qr",
    "qr-code",
    "canvas",
    "svg",
    "react-component"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/FatihKaratepe/react-qr.git"
  },
  "bugs": {
    "url": "https://github.com/FatihKaratepe/react-qr/issues"
  },
  "homepage": "https://github.com/FatihKaratepe/react-qr#readme"
}
